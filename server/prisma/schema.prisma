generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
  ACCOUNTANT
  CUSTOMER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  password          String
  phone             String?        @unique
  role              Role           @default(AGENT)
  isActive          Boolean        @default(true)
  lastLogin         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  refreshToken      RefreshToken[]
  clients           Client[]
  policies          Policy[]
  quotations        Quotation[]
  paymentsCreated   Payment[]      @relation("PaymentCreatedBy")
  paymentsUpdated   Payment[]      @relation("PaymentUpdatedBy")
  documentsUploaded Document[]     @relation("DocumentUploadedBy")
  documentsVerified Document[]     @relation("DocumentVerifiedBy")
  assignedRenewals  Renewal[]      @relation("AssignedAgentRenewals")
  activityLogs      ActivityLog[]
  auditTrails       AuditTrail[]
  commissionSplits  CommissionSplit[]
  payouts           Payout[]
  monthlyClosings   MonthlyClosing[]
  tasksAssigned     Task[] @relation("TaskAssignedTo")
  tasksCreated      Task[] @relation("TaskCreatedBy")
  assignedTickets   SupportTicket[] @relation("TicketAssignedTo")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Client {
  id            String         @id @default(cuid())
  firstName     String
  middleName    String?
  lastName      String
  email         String?        @unique
  phone         String         @unique
  dob           DateTime?
  gender        Gender?
  maritalStatus MaritalStatus?
  pan           String?        @unique
  aadhaar       String?        @unique
  occupation    String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  pincode       String?
  notes         String?
  isActive      Boolean        @default(true)
  createdById   String
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  policies      Policy[]
  quotations    Quotation[]
  documents     Document[]
  renewals      Renewal[]      @relation("ClientRenewals")
  workflows     Workflow[]
  familyMembers FamilyMember[]
  emergencyContact EmergencyContact?
  walletTransactions WalletTransaction[]
  supportTickets SupportTicket[]

  @@index([phone])
  @@index([email])
  @@index([pan])
}

model Company {
  id           String         @id @default(cuid())
  code         String         @unique
  description  String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  plans        Plan[]
  policies     Policy[]
  commissionRules CommissionRule[]
  commissions Commission[]
  invoices Invoice[]
  premiumRates PremiumRate[]
  quotations   Quotation[]
}

model Plan {
  id           String         @id @default(cuid())
  name         String
  code         String         @unique
  category     String?
  description  String?
  isActive     Boolean        @default(true)
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  policies     Policy[]
  premiumRates PremiumRate[]
  quotations   Quotation[]

  @@index([companyId])
  @@index([code])
}

enum PolicyStatus {
  DRAFT
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PolicyPaymentStatus {
  PENDING
  PAID
  PARTIAL
  FAILED
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  UPI
  CARD
  NET_BANKING
  CHEQUE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum DocumentType {
  AADHAAR
  PAN
  PASSPORT
  PHOTO
  POLICY
  MEDICAL_REPORT
  KYC
  CHEQUE
  OTHER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RenewalStatus {
  PENDING
  REMINDER_SENT
  RENEWED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  RENEWAL
  PAYMENT
  POLICY
  QUOTATION
  DOCUMENT
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  READ
}

enum WorkflowState {
  CREATED
  PREMIUM_CALCULATED
  QUOTATION_GENERATED
  APPROVED
  PAYMENT_PENDING
  PAYMENT_COMPLETED
  DOCUMENT_PENDING
  DOCUMENT_UPLOADED
  POLICY_ISSUED
  COMPLETED
}

model Policy {
  id            String              @id @default(cuid())
  policyNumber  String              @unique
  clientId      String
  companyId     String
  planId        String
  agentId       String
  sumInsured    Decimal             @db.Decimal(12, 2)
  premiumAmount Decimal             @db.Decimal(12, 2)
  gstAmount     Decimal             @db.Decimal(12, 2)
  issueDate     DateTime
  startDate     DateTime
  expiryDate    DateTime
  status        PolicyStatus        @default(PENDING)
  paymentStatus PolicyPaymentStatus @default(PENDING)
  remarks       String?
  client        Client              @relation(fields: [clientId], references: [id])
  company       Company             @relation(fields: [companyId], references: [id])
  plan          Plan                @relation(fields: [planId], references: [id])
  agent         User                @relation(fields: [agentId], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  payments      Payment[]
  documents     Document[]
  renewals      Renewal[]
  workflows     Workflow[]
  activityLogs  ActivityLog[]
  commissions   Commission[]
  nominees      Nominee[]

  @@index([policyNumber])
  @@index([clientId])
  @@index([companyId])
  @@index([status])
}

model PremiumRate {
  id         String    @id @default(cuid())
  companyId  String
  planId     String
  ageFrom    Int
  ageTo      Int
  gender     Gender?
  cityTier   String?
  familyType String?
  sumInsured Decimal   @db.Decimal(12, 2)
  tenure     Int
  premium    Decimal   @db.Decimal(12, 2)
  gst        Decimal   @db.Decimal(12, 2)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  company    Company   @relation(fields: [companyId], references: [id])
  plan       Plan      @relation(fields: [planId], references: [id])

  @@index([companyId, planId])
  @@index([ageFrom, ageTo])
}

model Quotation {
  id              String      @id @default(cuid())
  quotationNumber String      @unique
  clientId        String
  companyId       String
  planId          String
  premiumRateId   String?
  basePremium     Decimal     @db.Decimal(12, 2)
  gst             Decimal     @db.Decimal(12, 2)
  totalPremium    Decimal     @db.Decimal(12, 2)
  validTill       DateTime
  status          QuoteStatus @default(DRAFT)
  remarks         String?
  pdfPath         String?
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  client          Client      @relation(fields: [clientId], references: [id])
  company         Company     @relation(fields: [companyId], references: [id])
  plan            Plan        @relation(fields: [planId], references: [id])
  createdBy       User        @relation(fields: [createdById], references: [id])
  payments        Payment[]
  documents       Document[]
  workflows       Workflow[]

  @@index([clientId])
  @@index([companyId])
  @@index([status])
}

model Payment {
  id             String        @id @default(cuid())
  receiptNumber  String        @unique
  policyId       String
  quotationId    String?
  amount         Decimal       @db.Decimal(12, 2)
  gst            Decimal       @db.Decimal(12, 2)
  paymentMode    PaymentMode
  paymentStatus  PaymentStatus @default(PENDING)
  transactionId  String?
  paymentGateway String?
  paidAt         DateTime?
  remarks        String?
  createdById    String
  updatedById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  policy         Policy        @relation(fields: [policyId], references: [id])
  quotation      Quotation?    @relation(fields: [quotationId], references: [id])
  createdBy      User          @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?         @relation("PaymentUpdatedBy", fields: [updatedById], references: [id])

  @@index([receiptNumber])
  @@index([policyId])
  @@index([quotationId])
  @@index([paymentStatus])
}

model Document {
  id                 String             @id @default(cuid())
  clientId           String?
  expenseId          String?
  policyId           String?
  quotationId        String?
  documentType       DocumentType
  fileName           String
  originalFileName   String
  mimeType           String
  fileSize           Int
  fileUrl            String
  storageProvider    String
  uploadedById       String
  verifiedById       String?
  verificationStatus VerificationStatus @default(PENDING)
  remarks            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  client             Client?            @relation(fields: [clientId], references: [id])
  expense            Expense?           @relation(fields: [expenseId], references: [id])
  policy             Policy?            @relation(fields: [policyId], references: [id])
  quotation          Quotation?         @relation(fields: [quotationId], references: [id])
  uploadedBy         User               @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  verifiedBy         User?              @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id])

  @@index([clientId])
  @@index([policyId])
  @@index([quotationId])
  @@index([documentType])
  @@index([verificationStatus])
}

model Renewal {
  id                 String         @id @default(cuid())
  policyId           String
  clientId           String
  dueDate            DateTime
  renewalDate        DateTime?
  previousPremium    Decimal        @db.Decimal(12, 2)
  renewedPremium     Decimal?       @db.Decimal(12, 2)
  renewalStatus      RenewalStatus  @default(PENDING)
  reminderCount      Int            @default(0)
  lastReminderSentAt DateTime?
  assignedAgentId    String?
  remarks            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  policy             Policy         @relation(fields: [policyId], references: [id])
  client             Client         @relation("ClientRenewals", fields: [clientId], references: [id])
  assignedAgent      User?          @relation("AssignedAgentRenewals", fields: [assignedAgentId], references: [id])

  @@index([policyId])
  @@index([clientId])
  @@index([dueDate])
  @@index([renewalStatus])
}

model Notification {
  id            String              @id @default(cuid())
  title         String
  message       String
  type          NotificationType
  recipientId   String
  recipientType String              @default("CLIENT") // "CLIENT" or "USER"
  status        NotificationStatus  @default(PENDING)
  channel       NotificationChannel
  scheduledAt   DateTime?
  sentAt        DateTime?
  readAt        DateTime?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([recipientId])
  @@index([status])
  @@index([scheduledAt])
}

model Workflow {
  id            String          @id @default(cuid())
  clientId      String
  quotationId   String?
  policyId      String?
  currentState  WorkflowState   @default(CREATED)
  remarks       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  client        Client          @relation(fields: [clientId], references: [id])
  quotation     Quotation?      @relation(fields: [quotationId], references: [id])
  policy        Policy?         @relation(fields: [policyId], references: [id])

  @@index([clientId])
  @@index([quotationId])
  @@index([policyId])
  @@index([currentState])
}

model ActivityLog {
  id            String     @id @default(cuid())
  userId        String
  action        String
  module        String
  description   String
  policyId      String?
  createdAt     DateTime   @default(now())

  user          User       @relation(fields: [userId], references: [id])
  policy        Policy?    @relation(fields: [policyId], references: [id])

  @@index([userId])
  @@index([policyId])
}

model AuditTrail {
  id            String     @id @default(cuid())
  userId        String?
  tableName     String
  recordId      String
  action        String     // CREATE, UPDATE, DELETE
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  browser       String?
  device        String?
  createdAt     DateTime   @default(now())

  user          User?      @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
}


enum ExpenseCategory {
  OFFICE
  MARKETING
  SALARY
  SOFTWARE
  TRAVEL
  OTHER
}
enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}
enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}
enum CommissionStatus {
  PENDING
  GENERATED
  PAID
  CANCELLED
}
model CommissionRule {
  id                    String           @id @default(uuid())
  companyId             String
  productId             String?
  planId                String?
  commissionPct         Decimal          @db.Decimal(5, 2)
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  company               Company          @relation(fields: [companyId], references: [id])
  commissions           Commission[]
  @@index([companyId])
}
model Commission {
  id                    String           @id @default(uuid())
  commissionNumber      String           @unique
  companyId             String
  policyId              String
  ruleId                String?
  totalCommissionAmount Decimal          @db.Decimal(12, 2)
  status                CommissionStatus @default(PENDING)
  dueDate               DateTime?
  paidDate              DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  policy  Policy          @relation(fields: [policyId], references: [id])
  company Company         @relation(fields: [companyId], references: [id])
  rule    CommissionRule? @relation(fields: [ruleId], references: [id])
  splits  CommissionSplit[]
  @@index([policyId])
  @@index([companyId])
  @@index([status])
}
model CommissionSplit {
  id               String     @id @default(uuid())
  commissionId     String
  agentId          String
  splitPct         Decimal    @db.Decimal(5, 2)
  commissionAmount Decimal    @db.Decimal(12, 2)
  createdAt        DateTime   @default(now())
  commission       Commission @relation(fields: [commissionId], references: [id])
  agent            User       @relation(fields: [agentId], references: [id])
  @@index([commissionId])
  @@index([agentId])
}
model Expense {
  id           String          @id @default(uuid())
  category     ExpenseCategory
  vendor       String?
  amount       Decimal         @db.Decimal(12, 2)
  gst          Decimal         @default(0) @db.Decimal(12, 2)
  paymentMode  PaymentMode
  remarks      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  documents    Document[]
}
model Payout {
  id           String        @id @default(uuid())
  agentId      String
  amount       Decimal       @db.Decimal(12, 2)
  period       String
  status       PayoutStatus  @default(PENDING)
  bankRef      String?
  paidDate     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agent        User          @relation(fields: [agentId], references: [id])
  @@index([agentId])
  @@index([period])
}
model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  companyId     String
  amount        Decimal       @db.Decimal(12, 2)
  gst           Decimal       @default(0) @db.Decimal(12, 2)
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id])
  @@index([companyId])
}
model MonthlyClosing {
  id          String    @id @default(uuid())
  period      String    @unique
  isLocked    Boolean   @default(false)
  lockedById  String
  createdAt   DateTime  @default(now())
  lockedBy    User      @relation(fields: [lockedById], references: [id])
}
enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  assignedToId String?
  assignedTo  User?        @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdById String
  createdBy   User         @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FamilyMember {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  name          String
  relationship  String
  dob           DateTime?
  gender        Gender?
  aadhaar       String?
  isInsured     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Nominee {
  id            String   @id @default(cuid())
  policyId      String
  policy        Policy   @relation(fields: [policyId], references: [id])
  name          String
  relationship  String
  percentage    Float    @default(100)
  phone         String?
  createdAt     DateTime @default(now())
}

model EmergencyContact {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id])
  name          String
  phone         String
  relationship  String
  createdAt     DateTime @default(now())
}

model WalletTransaction {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  type          WalletTxType
  amount        Float
  description   String
  referenceId   String?
  createdAt     DateTime @default(now())
}

enum WalletTxType {
  PREMIUM_PAID
  REFUND
  CLAIM_SETTLED
  PAYOUT
}

model SupportTicket {
  id            String       @id @default(cuid())
  ticketNumber  String       @unique
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  subject       String
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(OPEN)
  assignedToId  String?
  assignedTo    User?        @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  replies       TicketReply[]
}

model TicketReply {
  id            String        @id @default(cuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id])
  senderId      String
  senderRole    String
  message       String
  createdAt     DateTime      @default(now())
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

